# Скопируй в .env и заполни своими значениями
# cp .env.example .env

# QEMU VM
BOOT_MODE=uefi
DISK_SIZE=4G

# Физический диск, пробрасываемый в VM как /disk2
# Найти: ls /dev/disk/by-id/
DISK_DEVICE=/dev/disk/by-id/ata-YOURMODEL_SERIALNUMBER

# Дополнительные аргументы QEMU
# Для USB passthrough: -device usb-host,vendorid=0xXXXX,productid=0xXXXX
# Найти vendorid/productid: lsusb
# Оставь пустым если не нужен USB passthrough
QEMU_EXTRA_ARGS=

# Host-порты (изменяй при конфликтах с другими сервисами)
HOST_PORT_WEBUI=8006
HOST_PORT_SSH=2222
HOST_PORT_HTTP=2280
HOST_PORT_HTTPS=2443
HOST_PORT_VNC=5900
